project_name = "aws-production"

environment = "dev"

aws_region = "ap-south-1"

vpc_cidr = "10.0.0.0/16"

availability_zones = [
  "ap-south-1a",
  "ap-south-1b"
]

public_subnet_cidrs = [
  "10.0.1.0/24",
  "10.0.2.0/24"
]

private_app_subnet_cidrs = [
  "10.0.11.0/24",
  "10.0.12.0/24"
]

private_db_subnet_cidrs = [
  "10.0.21.0/24",
  "10.0.22.0/24"
]

my_ip = "YOUR_PUBLIC_IP/32"
bastion_ami = "ami-xxxxxxxxxxxxxxxxx"

bastion_instance_type = "t3.micro"

key_name = "production-key"
certificate_arn = "arn:aws:acm:ap-south-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
####################################################
# Application Server
####################################################

app_ami = "ami-xxxxxxxxxxxxxxxxx"

app_instance_type = "t3.micro"
hosted_zone_id = "Z0123456789ABCDEFG"

domain_name = "app.example.com"
notification_email = "your-email@example.com"